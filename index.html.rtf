           <div className="flex items-center gap-3">\
             <div className="w-2 h-8 bg-indigo-500 rounded-full"></div>\
             <h2 className="text-indigo-100 text-base font-black uppercase tracking-[0.2em]">\
               2 The evolution of the human species\
             </h2>\
           </div>\
           <div className="text-indigo-400 text-[10px] font-bold tracking-widest uppercase hidden md:block text-right">\
             Interactive CLIL Learning Environment\
           </div>\
        </div>\
\
        \{/* Source Navigation Tabs */\}\
        <div className="bg-indigo-900/90 p-4 flex gap-3 overflow-x-auto border-b border-indigo-800">\
          \{[1, 2, 3, 4, 5].map((s) => (\
            <button\
              key=\{s\}\
              onClick=\{() => \{ setSource(s); setActiveWord(null); \}\}\
              className=\{`flex items-center gap-2 px-6 py-2.5 rounded-2xl text-xs font-black transition-all whitespace-nowrap tracking-wider uppercase $\{source === s ? 'bg-indigo-600 text-white shadow-[0_5px_15px_rgba(0,0,0,0.3)] scale-105' : 'text-indigo-300 hover:bg-indigo-800/50 hover:text-white'\}`\}\
            >\
              <FileText size=\{14\} /> Source \{s\}\
            </button>\
          ))\}\
        </div>\
\
        \{/* Dynamic Source Header */\}\
        <div className="bg-indigo-700 p-10 text-white relative">\
          <div className="absolute top-0 right-0 p-8 opacity-10">\
            <History size=\{140\} />\
          </div>\
          <div className="flex items-center gap-4 mb-4 relative z-10">\
            <div className="bg-white/20 p-3 rounded-2xl backdrop-blur-md">\
              \{source === 1 && <Info size=\{32\} />\}\
              \{source === 2 && <Map size=\{32\} />\}\
              \{source === 3 && <History size=\{32\} />\}\
              \{source === 4 && <Leaf size=\{32\} />\}\
              \{source === 5 && <Palette size=\{32\} />\}\
            </div>\
            <span className="text-indigo-100 uppercase tracking-[0.3em] text-xs font-black font-mono">Source \{source\}</span>\
          </div>\
          <h1 className="text-3xl md:text-5xl font-black leading-tight relative z-10 tracking-tight">\
            \{source === 1 && "New Human Species Found?"\}\
            \{source === 2 && "Homo erectus in South Africa"\}\
            \{source === 3 && "Australopithecus: Ape or Human?"\}\
            \{source === 4 && "Fighting Food Waste in Europe"\}\
            \{source === 5 && "Ancient Cave Art in Sulawesi"\}\
          </h1>\
        </div>\
\
        \{/* Complexity/Level Selector */\}\
        <div className="flex flex-col lg:flex-row lg:items-center justify-between p-8 bg-slate-50 border-b border-slate-200 gap-6 shadow-inner">\
          <div className="flex items-center gap-4">\
            <span className="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">Difficulty:</span>\
            <div className="flex bg-slate-200 rounded-2xl p-1.5 shadow-inner gap-1 overflow-x-auto">\
              \{[\
                \{ id: 'A1', label: 'A1 Beginner', icon: <GraduationCap size=\{14\} /> \},\
                \{ id: 'A2', label: 'A2 Elementary', icon: <Info size=\{14\} /> \},\
                \{ id: 'Original', label: 'Original Text (English)', icon: <AlignLeft size=\{14\} /> \}\
              ].map((lvl) => (\
                <button \
                  key=\{lvl.id\}\
                  onClick=\{() => \{ setLevel(lvl.id); setActiveWord(null); \}\}\
                  className=\{`px-5 py-2.5 rounded-xl text-xs font-black transition-all duration-300 flex items-center gap-2 whitespace-nowrap $\{level === lvl.id ? 'bg-white shadow-xl text-indigo-700' : 'text-slate-500 hover:text-indigo-600'\}`\}\
