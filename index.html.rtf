\
          \{/* Contextual Floating Tooltip */\}\
          \{activeWord && (\
            <div \
              className="absolute z-50 transition-opacity duration-300 ease-out"\
              style=\{tooltipStyles.containerStyle\}\
              onClick=\{(e) => e.stopPropagation()\}\
            >\
              <div className="bg-indigo-950 text-white rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)] p-7 w-80 border-2 border-indigo-400 relative">\
                <button onClick=\{() => setActiveWord(null)\} className="absolute -top-3 -right-3 bg-red-500 text-white rounded-full p-2 hover:bg-red-600 transition-transform hover:scale-110 shadow-xl border-2 border-white"><X size=\{18\} strokeWidth=\{3\} /></button>\
\
                \{/* Header met het Engelse woord en de uitspreek-knop */\}\
                <div className="flex items-center justify-between mb-4 pb-4 border-b border-indigo-800/50">\
                  <h3 className="text-2xl font-black text-white capitalize tracking-tight">\{activeWord.word\}</h3>\
                  <button \
                    onClick=\{(e) => speakWord(activeWord.word, e)\} \
                    className="bg-indigo-600 hover:bg-indigo-400 text-white p-2.5 rounded-full shadow-[0_0_15px_rgba(79,70,229,0.5)] transition-all hover:scale-110 active:scale-95 flex items-center justify-center border border-indigo-400 group"\
                    title="Beluister de Britse uitspraak"\
                  >\
                    <Volume2 size=\{20\} className="group-hover:animate-pulse" />\
                  </button>\
                </div>\
\
                <div className="mb-4">\
                  <div className="flex items-center gap-2 mb-2 opacity-70">\
                    <BookOpen size=\{16\} className="text-indigo-300" />\
                    <span className="text-indigo-300 font-black text-[9px] uppercase tracking-[0.2em]">English Definition</span>\
                  </div>\
                  <p className="text-xl text-white font-semibold leading-snug">"\{activeWord.info\}"</p>\
                </div>\
\
                <div className=\{`mt-5 pt-5 border-t border-indigo-800 transition-all duration-500 $\{activeWord.showTranslation ? 'opacity-100' : 'opacity-0'\}`\}>\
                  \{activeWord.showTranslation ? (\
                    <div className="flex flex-col gap-4">\
                      <div>\
                        <div className="flex items-center gap-2 mb-1 opacity-70">\
                          <Languages size=\{18\} className="text-yellow-400" />\
                          <span className="text-yellow-400 font-black text-[9px] uppercase tracking-[0.2em] italic">Dutch Translation</span>\
                        </div>\
                        <p className="text-2xl font-black text-yellow-400 tracking-tight leading-none uppercase">\{activeWord.nl\}</p>\
                      </div>\
                      <div>\
                        <div className="flex items-center gap-2 mb-1 opacity-70">\
                          <Languages size=\{18\} className="text-emerald-400" />\
                          <span className="text-emerald-400 font-black text-[9px] uppercase tracking-[0.2em] italic">French Translation</span>\
                        </div>\
                        <p className="text-2xl font-black text-emerald-400 tracking-tight leading-none uppercase">\{activeWord.fr\}</p>\
                      </div>\
                    </div>\
                  ) : (\
                    <div className="text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] text-center italic cursor-pointer animate-pulse bg-indigo-900/40 py-3 rounded-xl border border-indigo-800 border-dashed" onClick=\{() => setActiveWord(\{ ...activeWord, showTranslation: true \})\}>Click again for Dutch & French</div>\
                  )\}\
                </div>\
                \
                \{/* Visual Arrow for Tooltip */\}\
                <div className="absolute -bottom-2 w-5 h-5 bg-indigo-950 rotate-45 border-r-2 border-b-2 border-indigo-400 shadow-xl" style=\{tooltipStyles.arrowStyle\}></div>\
              </div>\
            </div>\
          )\}\
        </div>\
\
        \{/* Global Footer */\}\
        <div className="bg-slate-50 p-10 text-center text-[10px] text-slate-400 border-t border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4 px-16 uppercase tracking-[0.1em] font-black rounded-b-[2.5rem]">\
          <div className="flex items-center gap-6">\
            <span className="bg-slate-200 px-4 py-2 rounded-xl text-slate-500">Multilingual CLIL Engine v5.2</span>\
            <span className="text-indigo-300 font-black tracking-widest">History Education Focus</span>\
          </div>\
          <p className="opacity-50 tracking-tighter italic">Source navigation enabled with difficulty scaling</p>\
        </div>\
      </div>\
    </div>\
  );\
\};\
\
export default App;}